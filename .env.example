# ===== Shelf — Environment Variables =====

# --- App Identity ---
NEXT_PUBLIC_APP_NAME=Shelf
NEXT_PUBLIC_APP_EMOJI=📦
NEXT_PUBLIC_APP_DESCRIPTION=Self-hosted digital asset management with AI auto-tagging

# --- Browser UI Configuration ---
# Set this to the same value as API_KEY so the built-in upload/edit UI can call the API.
NEXT_PUBLIC_DAM_API_KEY=replace-me-with-the-api-key

# --- Configurable UI Metadata ---
# Use JSON arrays because these values are loaded into both server and client code.
# NEXT_PUBLIC_SHELF_PRODUCTS=["Product A","Product B","Product C"]
# NEXT_PUBLIC_SHELF_CONTENT_TYPES=["Product shot","Lifestyle","Flat lay","Banner","Social media","Video","UGC","Logo"]
# NEXT_PUBLIC_SHELF_COLLECTIONS=["Products","Marketing","Brand"]

# --- Database ---
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Storage (Cloudflare R2 / S3-compatible CDN URL) ---
R2_ACCOUNT_ID=your-account-id
R2_BUCKET=your-bucket-name
R2_TOKEN=your-api-token
R2_PUBLIC_URL=https://your-public-cdn-url.example.com

# --- Auth ---
API_KEY=replace-me-with-a-random-secret
UI_PASSWORD=replace-me-with-a-strong-password
# SHELF_AUTH_USERNAME=admin

# --- Gemini Auto-Tagging ---
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_PROMPT_PREFIX=You are a digital asset manager for Acme Co.
# GEMINI_PROMPT_CONTEXT=We sell journals, planners, and accessories.

# --- Optional R2 Import Tuning ---
# SHELF_IMPORT_PREFIX=raw-backup/dash-export-03-03-2026/
# SHELF_IMPORT_UPLOADED_BY=import

# --- Optional Legacy Dash Migration ---
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# DASH_CLIENT_ID=your-dash-client-id
# DASH_CLIENT_SECRET=your-dash-client-secret
